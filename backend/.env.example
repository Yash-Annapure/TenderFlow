# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (embeddings) ────────────────────────────────────────────────────
# Create account at https://dash.voyageai.com — free tier is sufficient for demo
VOYAGE_API_KEY=pa-...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Transaction-mode pooler URL — Dashboard → Settings → Database → Transaction mode (port 6543)
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K_DEFAULT=6
RETRIEVAL_TOP_K_CV=3
RETRIEVAL_THRESHOLD=0.72

# ── HITL ─────────────────────────────────────────────────────────────────────
MAX_HITL_ITERATIONS=3

# ── Output ───────────────────────────────────────────────────────────────────
DEFAULT_OUTPUT_FORMAT=docx

# ── Paths ────────────────────────────────────────────────────────────────────
KB_SEED_DIR=../Knowledge Base/kb
UPLOADS_DIR=./uploads
OUTPUTS_DIR=./outputs

# ── Admin ────────────────────────────────────────────────────────────────────
# Used to gate the POST /ingest/bulk endpoint
ADMIN_KEY=change-me-before-demo
